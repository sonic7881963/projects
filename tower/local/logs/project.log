326   float CCGetShadowFactorSoft (vec4 shadowPos) {
327     vec4 clipPosNew = ApplyShadowDepthBias_Orthographic(shadowPos, cc_shadowWHPBInfo.w);
328     vec3 clipPos = clipPosNew.xyz / clipPosNew.w * 0.5 + 0.5;
329     if (clipPos.x < 0.0 || clipPos.x > 1.0 ||
330         clipPos.y < 0.0 || clipPos.y > 1.0 ||
331         clipPos.z < 0.0 || clipPos.z > 1.0) { return 1.0; }
332     clipPos.xy = cc_cameraPos.w == 1.0 ? vec2(clipPos.xy.x, 1.0 - clipPos.xy.y) : clipPos.xy;
333     float offsetDepth = clipPos.z;
334     vec2 mapSize = cc_shadowWHPBInfo.xy;
335     vec2 oneTap = 1.0 / mapSize;
336     vec2 clipPos_offset = clipPos.xy + oneTap;
337     float block0, block1, block2, block3;
338     if (cc_shadowLPNNInfo.y > 0.000001) {
339       block0 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos.x, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
340       block1 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset.x, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
341       block2 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos.x, clipPos_offset.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
342       block3 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset.x, clipPos_offset.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
