250   mainPart = fract(data);
251   modPart = data - mainPart;
252 }
253 highp vec4 unpackHighpData (vec4 mainPart, vec4 modPart, const float modValue) {
254   highp vec4 data = mainPart * modValue;
255   return data + modPart * modValue;
256 }
257 void packHighpData (out vec4 mainPart, out vec4 modPart, highp vec4 data, const float modValue) {
258   highp vec4 divide = data / modValue;
259   mainPart = floor(divide);
260   modPart = (data - mainPart * modValue) / modValue;
261 }
262 float CCGetLinearDepthFromViewSpace(vec3 viewPos) {
263   float dist = length(viewPos);
264   return (dist - cc_shadowNFLSInfo.x) / (cc_shadowNFLSInfo.y - cc_shadowNFLSInfo.x);
265 }
266 float CCGetLinearDepth(vec3 worldPos) {
267   vec4 viewStartPos = cc_matLightView * vec4(worldPos.xyz, 1.0);
268   return CCGetLinearDepthFromViewSpace(viewStartPos.xyz);
269 }
270 #if CC_RECEIVE_SHADOW
271   uniform highp sampler2D cc_shadowMap;
272   uniform highp sampler2D cc_spotLightingMap;
273   vec4 ApplyShadowDepthBias_FaceNormal(vec4 shadowPos, vec3 worldNormal)
274   {
275     vec4 newShadowPos = shadowPos;
276     if(cc_shadowLPNNInfo.z > 0.0001)
277     {
278       vec4 viewNormal = cc_matLightView * vec4(worldNormal, 0.0);
279       if(viewNormal.z < 0.1)
280         newShadowPos.xy += viewNormal.xy * cc_shadowProjInfo.xy * cc_shadowLPNNInfo.z * clamp(viewNormal.z, 0.001, 0.1);
281     }
282     return newShadowPos;
283   }
284   vec4 ApplyShadowDepthBias_Perspective(vec4 shadowPos, float viewspaceDepthBias)
285   {
286     vec3 viewSpacePos;
287     viewSpacePos.xy = shadowPos.xy * cc_shadowProjInfo.zw;
288     viewSpacePos.z = shadowPos.z * cc_shadowInvProjDepthInfo.x + shadowPos.w * cc_shadowInvProjDepthInfo.y;
289     viewSpacePos.xyz += cc_shadowProjDepthInfo.z * normalize(viewSpacePos.xyz) * viewspaceDepthBias;
290     vec4 clipSpacePos;
291     clipSpacePos.xy = viewSpacePos.xy * cc_shadowProjInfo.xy;
292     clipSpacePos.zw = viewSpacePos.z * cc_shadowProjDepthInfo.xz + vec2(cc_shadowProjDepthInfo.y, 0.0);
293     if (cc_shadowNFLSInfo.z > 0.000001) {
294       clipSpacePos.z = CCGetLinearDepthFromViewSpace(viewSpacePos.xyz);
295       clipSpacePos.z = (clipSpacePos.z * 2.0 - 1.0) * clipSpacePos.w;
296     }
297     return clipSpacePos;
298   }
299   vec4 ApplyShadowDepthBias_Orthographic(vec4 shadowPos, float viewspaceDepthBias)
300   {
301     float coeffA = cc_shadowProjDepthInfo.x;
302     float coeffB = cc_shadowProjDepthInfo.y;
303     float viewSpacePos_z = (shadowPos.z - coeffB) / coeffA;
304     viewSpacePos_z += viewspaceDepthBias;
305     vec4 result = shadowPos;
306     result.z = viewSpacePos_z * coeffA + coeffB;
307     return result;
308   }
309   float CCGetShadowFactorHard (vec4 shadowPos) {
