370     if (cc_shadowLPNNInfo.y > 0.000001) {
371       block0 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset_L, clipPos_offset_U)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
372       block1 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos.x, clipPos_offset_U)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
373       block2 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset_R, clipPos_offset_U)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
374       block3 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset_L, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
375       block4 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos.x, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
376       block5 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset_R, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
377       block6 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset_L, clipPos_offset_D)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
378       block7 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos.x, clipPos_offset_D)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
379       block8 = step(offsetDepth, dot(texture(cc_shadowMap, vec2(clipPos_offset_R, clipPos_offset_D)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
380     } else {
381       block0 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos_offset_L, clipPos_offset_U)).x);
382       block1 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos.x, clipPos_offset_U)).x);
383       block2 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos_offset_R, clipPos_offset_U)).x);
384       block3 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos_offset_L, clipPos.y)).x);
385       block4 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos.x, clipPos.y)).x);
386       block5 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos_offset_R, clipPos.y)).x);
387       block6 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos_offset_L, clipPos_offset_D)).x);
388       block7 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos.x, clipPos_offset_D)).x);
389       block8 = step(offsetDepth, texture(cc_shadowMap, vec2(clipPos_offset_R, clipPos_offset_D)).x);
390     }
391     float coefX = mod(clipPos.x, oneTap.x) * mapSize.x;
392     float coefY = mod(clipPos.y, oneTap.y) * mapSize.y;
393     float shadow = 0.0;
394     float resultX = mix(block0, block1, coefX);
395     float resultY = mix(block3, block4, coefX);
396     shadow += mix(resultX , resultY, coefY);
397     resultX = mix(block1, block2, coefX);
398     resultY = mix(block4, block5, coefX);
399     shadow += mix(resultX , resultY, coefY);
400     resultX = mix(block3, block4, coefX);
401     resultY = mix(block6, block7, coefX);
402     shadow += mix(resultX, resultY, coefY);
403     resultX = mix(block4, block5, coefX);
404     resultY = mix(block7, block8, coefX);
405     shadow += mix(resultX, resultY, coefY);
406     return shadow * 0.25;
407   }
408   float CCGetSpotLightShadowFactorHard (vec4 shadowPos, vec3 worldPos) {
409     vec4 clipPosNew = ApplyShadowDepthBias_Perspective(shadowPos, cc_shadowWHPBInfo.w);
410     vec3 clipPos = clipPosNew.xyz / clipPosNew.w * 0.5 + 0.5;
411     if (clipPos.x < 0.0 || clipPos.x > 1.0 ||
412         clipPos.y < 0.0 || clipPos.y > 1.0 ||
413         clipPos.z < 0.0 || clipPos.z > 1.0) { return 1.0; }
414     clipPos.xy = cc_cameraPos.w == 1.0 ? vec2(clipPos.xy.x, 1.0 - clipPos.xy.y) : clipPos.xy;
415     float shadow = 0.0;
416     float closestDepth = 0.0;
417     float depth = clipPos.z;
418     if (cc_shadowLPNNInfo.y > 0.000001) {
419       closestDepth = dot(texture(cc_spotLightingMap, clipPos.xy), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0));
420     } else {
421       closestDepth = texture(cc_spotLightingMap, clipPos.xy).x;
422     }
423     shadow = step(depth, closestDepth);
424     return shadow;
425   }
426   float CCGetSpotLightShadowFactorSoft (vec4 shadowPos, vec3 worldPos) {
427     vec4 clipPosNew = ApplyShadowDepthBias_Perspective(shadowPos, cc_shadowWHPBInfo.w);
428     vec3 clipPos = clipPosNew.xyz / clipPosNew.w * 0.5 + 0.5;
429     if (clipPos.x < 0.0 || clipPos.x > 1.0 ||
430         clipPos.y < 0.0 || clipPos.y > 1.0 ||
431         clipPos.z < 0.0 || clipPos.z > 1.0) { return 1.0; }
432     clipPos.xy = cc_cameraPos.w == 1.0 ? vec2(clipPos.xy.x, 1.0 - clipPos.xy.y) : clipPos.xy;
433     float depth = 0.0;
434     if (cc_shadowNFLSInfo.z > 0.000001) {
435       depth = CCGetLinearDepth(worldPos);
436     } else {
437       depth = clipPos.z;
438     }
439     float bias = cc_shadowWHPBInfo.w;
440     vec2 oneTap = 1.0 / cc_shadowWHPBInfo.xy;
441     vec2 clipPos_offset = clipPos.xy + oneTap;
442     float block0, block1, block2, block3;
443     if (cc_shadowLPNNInfo.y > 0.000001) {
444       block0 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos.x, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
445       block1 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset.x, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
446       block2 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos.x, clipPos_offset.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
447       block3 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset.x, clipPos_offset.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
448     } else {
449       block0 = step(depth, texture(cc_spotLightingMap, vec2(clipPos.x, clipPos.y)).x);
450       block1 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset.x, clipPos.y)).x);
451       block2 = step(depth, texture(cc_spotLightingMap, vec2(clipPos.x, clipPos_offset.y)).x);
452       block3 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset.x, clipPos_offset.y)).x);
453     }
454     float coefX   = mod(clipPos.x, oneTap.x) * cc_shadowWHPBInfo.x;
455     float resultX = mix(block0, block1, coefX);
456     float resultY = mix(block2, block3, coefX);
457     float coefY   = mod(clipPos.y, oneTap.y) * cc_shadowWHPBInfo.y;
458     return mix(resultX, resultY, coefY);
459   }
460   float CCGetSpotLightShadowFactorSoft2X (vec4 shadowPos, vec3 worldPos) {
461     vec4 clipPosNew = ApplyShadowDepthBias_Perspective(shadowPos, cc_shadowWHPBInfo.w);
462     vec3 clipPos = clipPosNew.xyz / clipPosNew.w * 0.5 + 0.5;
463     if (clipPos.x < 0.0 || clipPos.x > 1.0 ||
464         clipPos.y < 0.0 || clipPos.y > 1.0 ||
465         clipPos.z < 0.0 || clipPos.z > 1.0) { return 1.0; }
466     clipPos.xy = cc_cameraPos.w == 1.0 ? vec2(clipPos.xy.x, 1.0 - clipPos.xy.y) : clipPos.xy;
467     float depth = 0.0;
468     if (cc_shadowNFLSInfo.z > 0.000001) {
469       depth = CCGetLinearDepth(worldPos);
470     } else {
471       depth = clipPos.z;
472     }
473     float bias = cc_shadowWHPBInfo.w;
474     vec2 mapSize = cc_shadowWHPBInfo.xy;
475     vec2 oneTap = 1.0 / mapSize;
476     float clipPos_offset_L = clipPos.x - oneTap.x;
477     float clipPos_offset_R = clipPos.x + oneTap.x;
478     float clipPos_offset_U = clipPos.y - oneTap.y;
479     float clipPos_offset_D = clipPos.y + oneTap.y;
480     float block0, block1, block2, block3, block4, block5, block6, block7, block8;
481     if (cc_shadowLPNNInfo.y > 0.000001) {
482       block0 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset_L, clipPos_offset_U)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
483       block1 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos.x, clipPos_offset_U)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
484       block2 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset_R, clipPos_offset_U)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
485       block3 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset_L, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
486       block4 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos.x, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
487       block5 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset_R, clipPos.y)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
488       block6 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset_L, clipPos_offset_D)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
489       block7 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos.x, clipPos_offset_D)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
490       block8 = step(depth, dot(texture(cc_spotLightingMap, vec2(clipPos_offset_R, clipPos_offset_D)), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0)));
491     } else {
492       block0 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset_L, clipPos_offset_U)).x);
493       block1 = step(depth, texture(cc_spotLightingMap, vec2(clipPos.x, clipPos_offset_U)).x);
494       block2 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset_R, clipPos_offset_U)).x);
495       block3 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset_L, clipPos.y)).x);
496       block4 = step(depth, texture(cc_spotLightingMap, vec2(clipPos.x, clipPos.y)).x);
497       block5 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset_R, clipPos.y)).x);
498       block6 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset_L, clipPos_offset_D)).x);
499       block7 = step(depth, texture(cc_spotLightingMap, vec2(clipPos.x, clipPos_offset_D)).x);
500       block8 = step(depth, texture(cc_spotLightingMap, vec2(clipPos_offset_R, clipPos_offset_D)).x);
501     }
502     float coefX = mod(clipPos.x, oneTap.x) * mapSize.x;
503     float coefY = mod(clipPos.y, oneTap.y) * mapSize.y;
504     float shadow = 0.0;
505     float resultX = mix(block0, block1, coefX);
506     float resultY = mix(block3, block4, coefX);
507     shadow += mix(resultX , resultY, coefY);
508     resultX = mix(block1, block2, coefX);
509     resultY = mix(block4, block5, coefX);
510     shadow += mix(resultX , resultY, coefY);
511     resultX = mix(block3, block4, coefX);
512     resultY = mix(block6, block7, coefX);
513     shadow += mix(resultX, resultY, coefY);
514     resultX = mix(block4, block5, coefX);
515     resultY = mix(block7, block8, coefX);
516     shadow += mix(resultX, resultY, coefY);
517     return shadow * 0.25;
518   }
519 #endif
520 #if CC_USE_IBL
521   uniform samplerCube cc_environment;
522   vec4 fragTextureLod (sampler2D tex, vec2 coord, float lod) {
523       return textureLod(tex, coord, lod);
524   }
525   vec4 fragTextureLod (samplerCube tex, vec3 coord, float lod) {
526       return textureLod(tex, coord, lod);
527   }
528   vec3 unpackRGBE (vec4 rgbe) {
529     return rgbe.rgb * pow(1.1, rgbe.a * 255.0 - 128.0);
530   }
531   #if CC_USE_DIFFUSEMAP
532     uniform samplerCube cc_diffuseMap;
533   #endif
534 #endif
535 float GGXMobile (float roughness, float NoH, vec3 H, vec3 N) {
536   vec3 NxH = cross(N, H);
537   float OneMinusNoHSqr = dot(NxH, NxH);
538   float a = roughness * roughness;
539   float n = NoH * a;
540   float p = a / (OneMinusNoHSqr + n * n);
541   return p * p;
542 }
543 float CalcSpecular (float roughness, float NoH, vec3 H, vec3 N) {
544   return (roughness * 0.25 + 0.25) * GGXMobile(roughness, NoH, H, N);
545 }
546 vec3 BRDFApprox (vec3 specular, float roughness, float NoV) {
547   const vec4 c0 = vec4(-1.0, -0.0275, -0.572, 0.022);
548   const vec4 c1 = vec4(1.0, 0.0425, 1.04, -0.04);
549   vec4 r = roughness * c0 + c1;
550   float a004 = min(r.x * r.x, exp2(-9.28 * NoV)) * r.x + r.y;
551   vec2 AB = vec2(-1.04, 1.04) * a004 + r.zw;
552   AB.y *= clamp(50.0 * specular.g, 0.0, 1.0);
553   return specular * AB.x + AB.y;
554 }
555 #if USE_REFLECTION_DENOISE
556   vec3 GetEnvReflectionWithMipFiltering(vec3 R, float roughness, float mipCount, float denoiseIntensity) {
557     #if CC_USE_IBL
558     	float mip = roughness * mipCount;
559     	float delta = (dot(dFdx(R), dFdy(R))) * 1000.0;
560     	float mipBias = mix(0.0, 5.0, clamp(delta, 0.0, 1.0));
561     	vec4 biased = fragTextureLod(cc_environment, R, mip + mipBias);
562      	vec4 filtered = texture(cc_environment, R);
563       #if CC_USE_IBL == 2
564       	biased.rgb = unpackRGBE(biased);
565       	filtered.rgb = unpackRGBE(filtered);
566       #else
567       	biased.rgb = SRGBToLinear(biased.rgb);
568       	filtered.rgb = SRGBToLinear(filtered.rgb);
569       #endif
570       return mix(biased.rgb, filtered.rgb, denoiseIntensity);
571     #else
572       return vec3(0.0, 0.0, 0.0);
573     #endif
574   }
575 #endif
576 struct StandardSurface {
577   vec4 albedo;
578   #if CC_PLATFORM_ANDROID_AND_WEBGL && CC_ENABLE_WEBGL_HIGHP_STRUCT_VALUES
579   vec3 position, position_fract_part;
580   #else
581   vec3 position;
582   #endif
583   vec3 normal;
584   vec3 emissive;
585   vec3 lightmap;
586   float lightmap_test;
587   float roughness;
588   float metallic;
589   float occlusion;
590 };
591 vec4 CCStandardShadingBase (StandardSurface s, vec4 shadowPos) {
592   vec3 diffuse = s.albedo.rgb * (1.0 - s.metallic);
593   vec3 specular = mix(vec3(0.04), s.albedo.rgb, s.metallic);
594   vec3 position;
595   #if CC_PLATFORM_ANDROID_AND_WEBGL && CC_ENABLE_WEBGL_HIGHP_STRUCT_VALUES
596   position = unpackHighpData(s.position, s.position_fract_part);
597   #else
598   position = s.position;
599   #endif
600   vec3 N = normalize(s.normal);
601   vec3 V = normalize(cc_cameraPos.xyz - position);
602   float NV = max(abs(dot(N, V)), 0.0);
603   specular = BRDFApprox(specular, s.roughness, NV);
604   vec3 L = normalize(-cc_mainLitDir.xyz);
605   vec3 H = normalize(L + V);
606   float NH = max(dot(N, H), 0.0);
607   float NL = max(dot(N, L), 0.0);
608   vec3 finalColor = NL * cc_mainLitColor.rgb * cc_mainLitColor.w;
609   vec3 diffuseContrib = diffuse;
610   #if USE_LIGHTMAP && !USE_BATCHING && !CC_FORWARD_ADD
611     if (s.lightmap_test > 0.0001) {
612       finalColor = s.lightmap.rgb;
613     }
614   #else
615     diffuseContrib /= 3.14159265359;
616   #endif
617   vec3 specularContrib = specular * CalcSpecular(s.roughness, NH, H, N);
618   vec3 dirlightContrib = (diffuseContrib + specularContrib);
619   float shadow = 1.0;
620   #if CC_RECEIVE_SHADOW
621     if (NL > 0.0 && cc_mainLitDir.w > 0.0) {
622       {
623         vec4 pos = ApplyShadowDepthBias_FaceNormal(shadowPos, N);
624         float pcf = cc_shadowWHPBInfo.z;
625         if (pcf > 1.9) shadow = CCGetShadowFactorSoft2X(pos);
626         else if (pcf > 0.9) shadow = CCGetShadowFactorSoft(pos);
627         else shadow = CCGetShadowFactorHard(pos);
628         shadow = mix(shadow, 1.0, cc_shadowNFLSInfo.w);
629       }
630     }
631   #endif
632   dirlightContrib *= shadow;
633   finalColor *= dirlightContrib;
634   float fAmb = 0.5 - N.y * 0.5;
635   vec3 ambDiff = mix(cc_ambientSky.rgb, cc_ambientGround.rgb, fAmb);
636   #if CC_USE_IBL
637     #if CC_USE_DIFFUSEMAP
638       vec4 diffuseMap = texture(cc_diffuseMap, N);
639       #if CC_USE_DIFFUSEMAP == 2
640         ambDiff = unpackRGBE(diffuseMap);
641       #else
642         ambDiff = SRGBToLinear(diffuseMap.rgb);
643       #endif
644     #endif
645     vec3 R = normalize(reflect(-V, N));
646     #if USE_REFLECTION_DENOISE
647       vec3 env = GetEnvReflectionWithMipFiltering(R, s.roughness, cc_ambientGround.w, 0.6);
648     #else
649       vec4 envmap = fragTextureLod(cc_environment, R, s.roughness * cc_ambientGround.w);
650       #if CC_USE_IBL == 2
651         vec3 env = unpackRGBE(envmap);
652       #else
653         vec3 env = SRGBToLinear(envmap.rgb);
654       #endif
655     #endif
656     finalColor += env * cc_ambientSky.w * specular * s.occlusion;
657   #endif
658   finalColor += ambDiff.rgb * cc_ambientSky.w * diffuse * s.occlusion;
659   finalColor += s.emissive;
660   return vec4(finalColor, s.albedo.a);
661 }
662 vec3 ACESToneMap (vec3 color) {
663   color = min(color, vec3(8.0));
664   const float A = 2.51;
665   const float B = 0.03;
666   const float C = 2.43;
667   const float D = 0.59;
668   const float E = 0.14;
669   return (color * (A * color + B)) / (color * (C * color + D) + E);
670 }
671 vec4 CCFragOutput (vec4 color) {
672   #if CC_USE_HDR
673     color.rgb = ACESToneMap(color.rgb);
674   #endif
675   color.rgb = sqrt(color.rgb);
676   return color;
677 }
678 in highp vec4 v_shadowPos;
679 #if USE_LIGHTMAP && !USE_BATCHING && !CC_FORWARD_ADD
680   in vec3 v_luv;
681   uniform sampler2D cc_lightingMap;
682   vec3 UnpackLightingmap(vec4 color) {
683     vec3 c;
684     float e = 1.0 + color.a * (8.0 - 1.0);
685     c.r = color.r * e;
686     c.g = color.g * e;
687     c.b = color.b * e;
688     return c;
689   }
690 #endif
691 in vec3 v_position;
692 in vec2 v_uv;
693 in vec2 v_uv1;
694 in vec3 v_normal;
695 #if USE_VERTEX_COLOR
696   in vec4 v_color;
697 #endif
698 #if USE_ALBEDO_MAP
699   uniform sampler2D albedoMap;
700 #endif
701 #if USE_NORMAL_MAP
702   in vec3 v_tangent;
703   in vec3 v_bitangent;
704   uniform sampler2D normalMap;
705 #endif
706 #if USE_PBR_MAP
707   uniform sampler2D pbrMap;
708 #endif
709 #if USE_METALLIC_ROUGHNESS_MAP
710   uniform sampler2D metallicRoughnessMap;
711 #endif
712 #if USE_OCCLUSION_MAP
713   uniform sampler2D occlusionMap;
714 #endif
715 #if USE_EMISSIVE_MAP
716   uniform sampler2D emissiveMap;
717 #endif
718 #if USE_ALPHA_TEST
719 #endif
720 void surf (out StandardSurface s) {
721   vec4 baseColor = albedo;
722   #if USE_VERTEX_COLOR
723     baseColor.rgb *= SRGBToLinear(v_color.rgb);
724     baseColor.a *= v_color.a;
725   #endif
726   #if USE_ALBEDO_MAP
727     vec4 texColor = texture(albedoMap, ALBEDO_UV);
728     texColor.rgb = SRGBToLinear(texColor.rgb);
729     baseColor *= texColor;
730   #endif
731   s.albedo = baseColor;
732   s.albedo.rgb *= albedoScaleAndCutoff.xyz;
733   #if USE_ALPHA_TEST
734     if (s.albedo.ALPHA_TEST_CHANNEL < albedoScaleAndCutoff.w) discard;
735   #endif
736   #if USE_LIGHTMAP && !USE_BATCHING && !CC_FORWARD_ADD
737     vec4 lightColor = texture(cc_lightingMap, v_luv.xy);
738     s.lightmap = UnpackLightingmap(lightColor);
739     s.lightmap_test = v_luv.z;
740   #endif
741   s.normal = v_normal;
742   #if USE_NORMAL_MAP
743     vec3 nmmp = texture(normalMap, NORMAL_UV).xyz - vec3(0.5);
744     s.normal =
745       (nmmp.x * emissiveScaleParam.w) * normalize(v_tangent) +
746       (nmmp.y * emissiveScaleParam.w) * normalize(v_bitangent) +
747       nmmp.z * normalize(s.normal);
748   #endif
749   #if CC_PLATFORM_ANDROID_AND_WEBGL && CC_ENABLE_WEBGL_HIGHP_STRUCT_VALUES
750   packHighpData(s.position, s.position_fract_part, v_position);
751   #else
752   s.position = v_position;
753   #endif
754   vec4 pbr = pbrParams;
755   #if USE_PBR_MAP
756     vec4 res = texture(pbrMap, PBR_UV);
757     pbr.x *= res.r;
758     pbr.y *= res.g;
759     pbr.z *= res.b;
760     pbr.w *= res.a;
761   #endif
762   #if USE_METALLIC_ROUGHNESS_MAP
763     vec4 metallicRoughness = texture(metallicRoughnessMap, PBR_UV);
764     pbr.z *= metallicRoughness.b;
765     pbr.y *= metallicRoughness.g;
