311     vec3 clipPos = clipPosNew.xyz / clipPosNew.w * 0.5 + 0.5;
312     if (clipPos.x < 0.0 || clipPos.x > 1.0 ||
313         clipPos.y < 0.0 || clipPos.y > 1.0 ||
314         clipPos.z < 0.0 || clipPos.z > 1.0) { return 1.0; }
315     clipPos.xy = cc_cameraPos.w == 1.0 ? vec2(clipPos.xy.x, 1.0 - clipPos.xy.y) : clipPos.xy;
316     float shadow = 0.0;
317     float closestDepth = 0.0;
318     if (cc_shadowLPNNInfo.y > 0.000001) {
319       closestDepth = dot(texture(cc_shadowMap, clipPos.xy), vec4(1.0, 1.0 / 255.0, 1.0 / 65025.0, 1.0 / 16581375.0));
320     } else {
