520 #if CC_USE_IBL
521   uniform samplerCube cc_environment;
522   vec4 fragTextureLod (sampler2D tex, vec2 coord, float lod) {
523       return textureLod(tex, coord, lod);
524   }
525   vec4 fragTextureLod (samplerCube tex, vec3 coord, float lod) {
526       return textureLod(tex, coord, lod);
527   }
528   vec3 unpackRGBE (vec4 rgbe) {
529     return rgbe.rgb * pow(1.1, rgbe.a * 255.0 - 128.0);
530   }
531   #if CC_USE_DIFFUSEMAP
532     uniform samplerCube cc_diffuseMap;
533   #endif
534 #endif
535 float GGXMobile (float roughness, float NoH, vec3 H, vec3 N) {
536   vec3 NxH = cross(N, H);
537   float OneMinusNoHSqr = dot(NxH, NxH);
538   float a = roughness * roughness;
539   float n = NoH * a;
540   float p = a / (OneMinusNoHSqr + n * n);
541   return p * p;
542 }
543 float CalcSpecular (float roughness, float NoH, vec3 H, vec3 N) {
544   return (roughness * 0.25 + 0.25) * GGXMobile(roughness, NoH, H, N);
545 }
546 vec3 BRDFApprox (vec3 specular, float roughness, float NoV) {
547   const vec4 c0 = vec4(-1.0, -0.0275, -0.572, 0.022);
548   const vec4 c1 = vec4(1.0, 0.0425, 1.04, -0.04);
549   vec4 r = roughness * c0 + c1;
550   float a004 = min(r.x * r.x, exp2(-9.28 * NoV)) * r.x + r.y;
551   vec2 AB = vec2(-1.04, 1.04) * a004 + r.zw;
552   AB.y *= clamp(50.0 * specular.g, 0.0, 1.0);
553   return specular * AB.x + AB.y;
554 }
555 #if USE_REFLECTION_DENOISE
556   vec3 GetEnvReflectionWithMipFiltering(vec3 R, float roughness, float mipCount, float denoiseIntensity) {
557     #if CC_USE_IBL
558     	float mip = roughness * mipCount;
559     	float delta = (dot(dFdx(R), dFdy(R))) * 1000.0;
560     	float mipBias = mix(0.0, 5.0, clamp(delta, 0.0, 1.0));
561     	vec4 biased = fragTextureLod(cc_environment, R, mip + mipBias);
562      	vec4 filtered = texture(cc_environment, R);
563       #if CC_USE_IBL == 2
564       	biased.rgb = unpackRGBE(biased);
565       	filtered.rgb = unpackRGBE(filtered);
566       #else
567       	biased.rgb = SRGBToLinear(biased.rgb);
568       	filtered.rgb = SRGBToLinear(filtered.rgb);
569       #endif
570       return mix(biased.rgb, filtered.rgb, denoiseIntensity);
571     #else
572       return vec3(0.0, 0.0, 0.0);
573     #endif
574   }
575 #endif
